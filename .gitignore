# Root gitignore for dotdet repository

# Logs
logs
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
playwright-report/
test-results/

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Node.js
node_modules/
**/node_modules/
.dist/
dist/
dist-ssr/
*.local

# Vite / frontend build
public/build/
coverage/

# .NET build artifacts
bin/
obj/
**/[Bb]in/
**/[Oo]bj/

# .NET packages and generated files
*.nupkg
*.snupkg
*.symbols.nupkg
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets
packages/

# Visual Studio and editor folders
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.dotCover

# VS Code settings
.vscode/*
!.vscode/extensions.json

# Test results and coverage
TestResults/
*.trx
.coverage
coverage/

# Environment files
.env
.env.*.local

# Temporary files
*.tmp
*.temp
*.bak
*.orig
*.swp

# Sample and working directories
samples/**/bin/
samples/**/obj/
work/**/bin/
work/**/obj/

# Ignore editor-specific files
*.log
*~

# Ignore backend and frontend runtime artifacts
backend/*.pid
frontend/*.pid
